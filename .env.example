# .env.example — Copy this to .env for local development

# PostgreSQL
POSTGRES_PASSWORD=

# Directus
DIRECTUS_KEY=
DIRECTUS_SECRET=
DIRECTUS_PUBLIC_URL=http://localhost:8055
DIRECTUS_ADMIN_EMAIL=
DIRECTUS_ADMIN_PASSWORD=
DIRECTUS_PORT=8055
DIRECTUS_TELEMETRY=false
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAME_SITE=lax

# Nuxt (optional)
NUXT_PORT=3000
NUXT_PUBLIC_DIRECTUS_URL=
NUXT_DIRECTUS_ADMIN_TOKEN=